{
  "name": "qaizo-workspace",
  "private": true,
  "version": "0.1.0",
  "description": "Qaizo Studio monorepo. Engine + apps (Senik — first product, mental models). Qaizo's other products live separately.",
  "workspaces": [
    "engine",
    "apps/*"
  ],
  "scripts": {
    "validate": "node scripts/validate-card.js",
    "validate:seed": "node scripts/validate-card.js content/seed",
    "audit:content": "node scripts/audit-content.js",
    "cards:stats": "node scripts/cards-stats.js",
    "check:secrets": "node scripts/check-secrets.js",
    "fonts:download": "node scripts/download-fonts.js",
    "syntax:check": "node scripts/syntax-check.js",
    "seed:upload": "node scripts/upload-seed.js",
    "rules:deploy": "node scripts/deploy-firestore-rules.js",
    "icons:generate": "node scripts/generate-icons.js",
    "senik": "npm --workspace senik start",
    "senik:android": "npm --workspace senik run android",
    "senik:ios": "npm --workspace senik run ios",
    "biased": "npm --workspace biased start",
    "biased:android": "npm --workspace biased run android",
    "fonts:download:biased": "node scripts/download-fonts-biased.js",
    "icons:generate:biased": "node scripts/generate-icons-biased.js"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "ajv": "^8.17.1",
    "jimp": "^1.6.1"
  },
  "dependencies": {
    "firebase-admin": "^13.8.0"
  }
}
