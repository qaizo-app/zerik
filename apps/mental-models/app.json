{
  "expo": {
    "name": "Mental Models",
    "slug": "mental-models",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "scheme": "mentalmodels",
    "splash": {
      "resizeMode": "cover",
      "backgroundColor": "#0E1014"
    },
    "assetBundlePatterns": ["**/*"],
    "_ios_disabled_until_apple_developer": {
      "bundleIdentifier": "com.zerik.mentalmodels",
      "supportsTablet": false
    },
    "android": {
      "package": "com.zerik.mentalmodels",
      "adaptiveIcon": {
        "backgroundColor": "#0E1014"
      }
    },
    "plugins": [
      "expo-font"
    ],
    "extra": {
      "appSlug": "mental-models"
    }
  }
}
